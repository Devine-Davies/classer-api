{
    "private": true,
    "type": "module",
    "scripts": {
        "start": "vite",
        "build": "vite build",
        "routes:postman": "node scripts/routes-json-to-postman.mjs api-routes.json postman-api-collection.json",
        "routes:api:json:sail": "./vendor/bin/sail php artisan route:list --path=api --json > api-routes.json",
        "routes:postman:env": "node scripts/create-postman-environment.mjs postman-api-environment.json http://localhost",
        "routes:postman:all": "npm run routes:postman && npm run routes:postman:env"
    },
    "devDependencies": {
        "autoprefixer": "^10.4.16",
        "axios": "^1.6.1",
        "laravel-vite-plugin": "^0.8.0",
        "postcss": "^8.4.31",
        "tailwindcss": "^3.4.1",
        "vite": "^4.0.0"
    },
    "dependencies": {
        "@stripe/stripe-js": "^4.0.0",
        "echarts": "^6.1.0",
        "htmx.org": "^1.9.9"
    }
}
